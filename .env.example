# ============================================================
# .env.example — SAFE TO COMMIT (dummy values only)
# Copy this to .env and fill in real values locally.
# .env itself is gitignored — never commit real secrets.
# ============================================================

# --- Postgres (superuser, used only for provisioning) ---
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=changeme_local_dev_only
POSTGRES_DB=insurance_platform

# --- Scoped app DB users (least privilege — see db/init.sql) ---
# Core API: read/write on policies, claims, users. NO access to audit_log writes beyond INSERT.
CORE_API_DB_USER=core_api_svc
CORE_API_DB_PASSWORD=changeme_core_api_local

# Document service: read/write on documents table only
DOCUMENT_SVC_DB_USER=document_svc
DOCUMENT_SVC_DB_PASSWORD=changeme_document_svc_local

# Auditor: read-only on audit_log, no access to other tables
AUDITOR_DB_USER=auditor_ro
AUDITOR_DB_PASSWORD=changeme_auditor_local

# --- Redis ---
REDIS_PASSWORD=changeme_redis_local

# --- Keycloak (local dev admin only — real deploys use a proper IdP config) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak_admin_local
KEYCLOAK_DB_USER=keycloak_svc
KEYCLOAK_DB_PASSWORD=changeme_keycloak_local

# --- Field-level encryption key for sensitive columns (medical/ID data) ---
# NEVER reuse this key across environments. Generate with: openssl rand -base64 32
# In production this comes from a secrets manager, not a .env file.
FIELD_ENCRYPTION_KEY=changeme_generate_with_openssl_rand

# --- App config ---
API_PORT=8000
ENVIRONMENT=local
