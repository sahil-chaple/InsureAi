# Database URL
# For local development: sqlite:///./insureai.db
# For Docker: postgresql://postgres:postgres@db:5432/insureai
DATABASE_URL=sqlite:///./insureai.db

# Redis URL for rate limiting (Optional: if empty, will fallback to in-memory)
REDIS_URL=

# JWT Settings
# Generate a secret key: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_key_here_must_be_long_and_random
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Fernet symmetric encryption key for sensitive medical fields (date_of_birth, pre_existing_conditions)
# Generate key using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# Allowed origins for CORS (comma-separated list)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
